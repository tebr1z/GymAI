{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=gymdb;Username=postgres;Password=1234;Pooling=true;Minimum Pool Size=0;Maximum Pool Size=100;Connection Idle Lifetime=300;Timeout=30;Command Timeout=60"
  },
  "Jwt": {
    "Secret": "CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS",
    "Issuer": "GymFit",
    "Audience": "GymFitClients",
    "AccessTokenMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "OpenAi": {
    "ApiKey": "",
    "BaseUrl": "https://api.openai.com/v1/",
    "Model": "gpt-4o-mini",
    "TimeoutSeconds": 120,
    "MaxRetries": 2,
    "RetryBaseDelayMilliseconds": 750,
    "MinAssistantContentLength": 8,
    "MaxAssistantContentLength": 200000,
    "MaxRawResponseCharacters": 2000000
  },
  "SubscriptionTierLimits": {
    "FreeAiRequestsPerMonth": 10,
    "ProAiRequestsPerMonth": 200,
    "PremiumAiRequestsPerMonth": -1
  }
}
